# Copy to .env for standalone dev. In the Electron app these are injected automatically.

# Shared secret between UI and backend. Electron mints one per launch; set manually
# only when running the backend standalone.
LOCAL_API_TOKEN=change-me

# Anthropic API key for the Wyckoff narrative. Optional: without it the quantitative
# analysis still works, only the AI commentary is skipped.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI API key for the Codex narrative provider. Optional, same fallback
# behavior as the Anthropic key above.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# SQLite database file.
DB_PATH=chart_volume.db

HOST=127.0.0.1
PORT=8787
